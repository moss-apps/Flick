<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/flagship_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_mini_player_card"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/flagship_art"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:contentDescription="@string/widget_open_app"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_default_art" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/flagship_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/product_sans"
            android:maxLines="2"
            android:textColor="#FFF5F5F5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/flagship_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/product_sans"
            android:singleLine="true"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/flagship_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@null"
                android:contentDescription="@string/widget_previous"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_previous" />

            <ImageButton
                android:id="@+id/flagship_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_button_play_bg"
                android:contentDescription="@string/widget_play_pause"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_play" />

            <ImageButton
                android:id="@+id/flagship_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@null"
                android:contentDescription="@string/widget_next"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_next" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/flagship_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="6dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_white" />
    </LinearLayout>

</LinearLayout>