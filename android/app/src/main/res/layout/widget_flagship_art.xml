<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/flagship_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/flagship_art"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/widget_open_app"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_default_art" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/widget_background"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/flagship_shuffle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_button_transport_bg"
                android:contentDescription="@string/widget_shuffle"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_lucide_shuffle" />

            <ImageButton
                android:id="@+id/flagship_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/widget_button_transport_bg"
                android:contentDescription="@string/widget_previous"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_lucide_skip_back" />

            <ImageButton
                android:id="@+id/flagship_play_pause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/widget_button_play_bg"
                android:contentDescription="@string/widget_play_pause"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_lucide_play" />

            <ImageButton
                android:id="@+id/flagship_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/widget_button_transport_bg"
                android:contentDescription="@string/widget_next"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_lucide_skip_forward" />

            <ImageButton
                android:id="@+id/flagship_repeat"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/widget_button_transport_bg"
                android:contentDescription="@string/widget_repeat"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/widget_ic_lucide_repeat" />
        </LinearLayout>

        <ImageView
            android:id="@+id/flagship_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:contentDescription="@string/widget_nothing_playing"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/flagship_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:contentDescription="@string/widget_nothing_playing"
            android:scaleType="fitCenter"
            android:visibility="gone" />
    </LinearLayout>

</FrameLayout>
